{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: up",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev-up.sh",
      "args": [
        "${input:uiScheme}"
      ],
      "runOptions": {
        "instanceLimit": 1
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "review: live subscriptions",
      "type": "shell",
      "command": "go",
      "args": [
        "run",
        "./cmd/frontend-review",
        "-case-dir",
        ".tmp/review/manual"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: rebase current branch onto main",
      "type": "shell",
      "command": "git fetch origin main && git rebase origin/main",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: force push current branch",
      "type": "shell",
      "command": "git",
      "args": [
        "push",
        "--force-with-lease",
        "origin",
        "HEAD"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: commit current changes to main (no push)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/commit-current-changes-to-main.sh",
      "args": [
        "${input:mainCommitMessage}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "uiScheme",
      "type": "pickString",
      "description": "Select the UI scheme to open in the local dev flow",
      "options": [
        "a",
        "b",
        "c"
      ],
      "default": "a"
    },
    {
      "id": "mainCommitMessage",
      "type": "promptString",
      "description": "Commit message (commits to local main only; does not push)"
    }
  ]
}
