{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: up",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/dev-up-vscode-task.sh",
        "a"
      ],
      "runOptions": {
        "instanceLimit": 1
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: rebase dev onto local main",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/rebase-ui-branches.sh",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: force push dev",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/force-push-ui-branches.sh",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: commit staged changes to main (no push)",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/commit-current-changes-to-main.sh",
        "${input:mainCommitMessage}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: commit staged changes to dev (no push)",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/commit-current-changes-to-main.sh",
        "${input:devCommitMessage}"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "CHAIN_SUBCONVERTER_MAIN_BRANCH": "dev",
          "CHAIN_SUBCONVERTER_MAIN_REMOTE": "origin"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "mainCommitMessage",
      "type": "promptString",
      "description": "Commit message (commits staged changes to local main, clears matching current-branch changes; does not push)"
    },
    {
      "id": "devCommitMessage",
      "type": "promptString",
      "description": "Commit message (commits staged changes to local dev, clears matching current-branch changes; does not push)"
    }
  ]
}
