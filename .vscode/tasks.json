{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: up",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/dev-up-vscode-task.sh",
        "${input:uiScheme}"
      ],
      "runOptions": {
        "instanceLimit": 1
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: rebase UI branches onto local main",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/rebase-ui-branches.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: force push UI branches",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/force-push-ui-branches.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: commit staged changes to main (no push)",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/commit-current-changes-to-main.sh",
        "${input:mainCommitMessage}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "uiScheme",
      "type": "pickString",
      "description": "Select the UI scheme to open in the local dev flow",
      "options": [
        "a",
        "b",
        "c"
      ],
      "default": "a"
    },
    {
      "id": "mainCommitMessage",
      "type": "promptString",
      "description": "Commit message (commits staged changes to local main, clears matching current-branch changes; does not push)"
    }
  ]
}
