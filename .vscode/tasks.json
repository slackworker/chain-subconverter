{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: up",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev-up-vscode-task.sh",
      "args": [
        "${input:uiScheme}",
        "${input:devPortOffset}"
      ],
      "runOptions": {
        "instanceLimit": 1
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: rebase UI branches onto local main",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/rebase-ui-branches.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: force push UI branches",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/force-push-ui-branches.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "git: commit staged changes to main (no push)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/commit-current-changes-to-main.sh",
      "args": [
        "${input:mainCommitMessage}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "uiScheme",
      "type": "pickString",
      "description": "Select the UI scheme to open in the local dev flow",
      "options": [
        "a",
        "b",
        "c"
      ],
      "default": "a"
    },
    {
      "id": "devPortOffset",
      "type": "pickString",
      "description": "Port offset for concurrent worktrees: 0 uses 25500/11200/5173-5175; 10 uses 25510/11210/5183-5185",
      "options": [
        "0",
        "10",
        "20",
        "30"
      ],
      "default": "0"
    },
    {
      "id": "mainCommitMessage",
      "type": "promptString",
      "description": "Commit message (commits staged changes to local main, clears matching current-branch changes; does not push)"
    }
  ]
}
