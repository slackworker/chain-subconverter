{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: up",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev-up.sh",
      "args": [
        "${input:uiScheme}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "review: live subscriptions",
      "type": "shell",
      "command": "go",
      "args": [
        "run",
        "./cmd/frontend-review",
        "-name",
        "${input:reviewCaseName}",
        "-landing-url",
        "${input:landingSubscriptionURL}",
        "-transit-url",
        "${input:transitSubscriptionURL}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "uiScheme",
      "type": "pickString",
      "description": "Select the UI scheme to open in the local dev flow",
      "options": [
        "a",
        "b",
        "c"
      ],
      "default": "a"
    },
    {
      "id": "reviewCaseName",
      "type": "promptString",
      "description": "Name of the live review case directory",
      "default": "live-review"
    },
    {
      "id": "landingSubscriptionURL",
      "type": "promptString",
      "description": "Landing subscription URL",
      "default": "http://192.168.100.1:3001/7xK9pLm2Qr4vB6yN8sT3/download/Landing-Subscription"
    },
    {
      "id": "transitSubscriptionURL",
      "type": "promptString",
      "description": "Transit or airport subscription URL",
      "default": "http://192.168.100.1:3001/7xK9pLm2Qr4vB6yN8sT3/download/Airport-Subscription"
    }
  ]
}
